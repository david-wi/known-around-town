# Move to .github/workflows/deploy.yml after granting the GH token `workflow` scope.
name: Deploy
on:
  push:
    branches: [main]
  workflow_dispatch: {}
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - env:
          DEPLOY_HOST: ${{ secrets.DEPLOY_HOST }}
          DEPLOY_USER: ${{ secrets.DEPLOY_USER }}
          DEPLOY_KEY: ${{ secrets.DEPLOY_KEY }}
        run: |
          mkdir -p ~/.ssh
          echo "$DEPLOY_KEY" > ~/.ssh/id
          chmod 600 ~/.ssh/id
          ssh-keyscan -p 2222 -H "$DEPLOY_HOST" >> ~/.ssh/known_hosts 2>/dev/null
          ssh -i ~/.ssh/id -p 2222 -o StrictHostKeyChecking=yes "$DEPLOY_USER@$DEPLOY_HOST" \
            'bash /opt/who-knows-local/scripts/deploy.sh'
