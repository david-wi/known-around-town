# MongoDB
# In production, set MONGODB_URL to the managed MongoDB Atlas connection
# string (mongodb+srv://...). The app refuses to start against a local Mongo
# (localhost / the docker "mongo" service) unless ALLOW_LOCAL_MONGODB=true is
# set — this prevents a production deploy from ever silently falling back to a
# local database.
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=who_knows_local

# Local development ONLY: opt in to using a local Mongo (the line above points
# at the docker-compose "mongo" service). Never set this in production.
# This flag ALSO marks the database as a safe target for the demo-data
# seed/reset scripts — together with a local MONGODB_URL host, it lets the
# destructive seed run freely on your machine.
ALLOW_LOCAL_MONGODB=true

# Demo-data seed/reset against PRODUCTION — leave UNSET everywhere except the
# deploy pipeline. The seed scripts DELETE stale records as part of re-seeding,
# so they refuse to touch a production (Atlas) database unless this is set on
# purpose. The deploy script sets it automatically for the intentional
# production seed. Never set this in a developer shell — it removes the
# safety net that stops an accidental wipe of the live database.
# KAT_ALLOW_PRODUCTION_RESET=true

# Domain configuration — comma-separated list of network base domains the server answers on.
# Format: <network_slug>:<domain_suffix>
# Example: a request to "miami.knowsbeauty.ai.devintensive.com" matches the "beauty:knowsbeauty.ai.devintensive.com" entry
# and resolves to (network=beauty, city=miami).
NETWORK_DOMAINS=beauty:knowsbeauty.ai.devintensive.com,wellness:knowswellness.ai.devintensive.com,health:knowshealth.ai.devintensive.com,beauty:knowsbeauty.localhost,wellness:knowswellness.localhost,health:knowshealth.localhost

# Optional admin API key (X-API-Key header) for write endpoints
ADMIN_API_KEY=

# Marketing AI (Instagram captions, ad copy). When MARKETING_AI_ENABLED is
# truthy, /api/v1/marketing-ai/* endpoints become reachable. Stage's compose
# defaults this to true; production keeps it off until the owner dashboard
# ships. KAT_AI_GATEWAY_KEY is a personal key (scope: ai_gateway) minted in
# Expertly Identity; it authenticates the server-to-server call to
# admin.ai.devintensive.com/api/public/ai-config/call.
MARKETING_AI_ENABLED=
KAT_AI_GATEWAY_KEY=

# Owner login email. RESEND_API_KEY is optional for local development; when
# absent, owner login codes are written to the app log instead of emailed.
RESEND_API_KEY=
OWNER_EMAIL_FROM_NAME=Knows Beauty
OWNER_EMAIL_FROM_ADDRESS=noreply@knowsbeauty.ai.devintensive.com
# Inbox that receives an alert email whenever an owner submits a new claim.
# Defaults to hello@knowsbeauty.com — override to route alerts elsewhere.
ADMIN_NOTIFY_EMAIL=hello@knowsbeauty.com

# Stripe billing (Pro subscription — $99/year).
# STRIPE_SECRET_KEY:     sk_live_... (or sk_test_... for dev/stage)
# STRIPE_WEBHOOK_SECRET: whsec_...  (from Stripe Dashboard > Webhooks)
# STRIPE_PRICE_ID_PRO:   price_...  (the annual Pro plan price ID)
# Leave empty to disable billing entirely (owners see the upgrade card but get
# a "coming soon" error when they try to check out).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Google Analytics 4. Set to your Measurement ID (e.g. G-XXXXXXXXXX) to enable
# site-wide tracking. Leave empty to disable — no script tag is emitted.
GA_MEASUREMENT_ID=  # Google Analytics 4 Measurement ID (G-XXXXXXXXXX)

# Server
PORT=8000
LOG_LEVEL=INFO
